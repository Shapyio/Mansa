{
  "name": "Mansa Dev",
  "dockerComposeFile": "../docker-compose.yml", // Use docker-compose
  "service": "app", // The name of your main container
  "workspaceFolder": "/app",
  "settings": {
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python3.12", // Set python path
    "terminal.integrated.shell.linux": "/bin/bash"
  },
  "extensions": [
    "ms-vscode.cpptools",
    "ms-vscode.cmake-tools",
    "ms-python.python"
  ],
  "forwardPorts": [
    5432
  ],
  "postCreateCommand": "mkdir -p build && cmake -S . -B build",
  "shutdownAction": "stopCompose"
}